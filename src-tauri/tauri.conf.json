{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clip2Gif",
  "version": "0.1.0",
  "identifier": "com.clip2gif.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Clip2Gif",
        "width": 980,
        "height": 720,
        "minWidth": 860,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
